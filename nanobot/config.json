{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "coder-model",
      "provider": "custom"
    }
  },
  "providers": {
    "custom": {
      "apiKey": "${LLM_API_KEY}",
      "apiBase": "${LLM_API_BASE_URL}"
    }
  },
  "channels": {
    "webchat": {
      "enabled": true,
      "allow_from": ["*"]
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "uv",
        "args": ["run", "-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "${NANOBOT_LMS_BACKEND_URL}",
          "NANOBOT_LMS_API_KEY": "${NANOBOT_LMS_API_KEY}",
          "VICTORIALOGS_URL": "http://victorialogs:9428",
          "VICTORIATRACES_URL": "http://victoriatraces:10428"
        }
      }
    }
  }
}
