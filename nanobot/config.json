{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "coder-model",
      "provider": "custom"
    }
  },
  "providers": {
    "custom": {
      "apiKey": "test-qwen-key",
      "apiBase": "http://localhost:42005/v1"
    }
  },
  "channels": {
    "webchat": {
      "enabled": true,
      "allow_from": ["*"]
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "uv",
        "args": ["run", "-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "http://localhost:42001",
          "NANOBOT_LMS_API_KEY": "test-secret-key"
        }
      }
    }
  }
}
